# Supermemory local server (self-hosted binary, listens on :6767)
# API key is printed on first boot and cached at ~/.supermemory/api-key
SUPERMEMORY_API_KEY=
SUPERMEMORY_BASE_URL=http://localhost:6767
SUPERMEMORY_CONTAINER_TAG=trading_system

# Groq powers everything that reasons: the six trading agents + Reflection Agent
# + Consolidation Agent (agents/llm.py), and the Supermemory server process
# (scripts/run_memory_server.sh exports it). Free tier is enough.
GROQ_API_KEY=
